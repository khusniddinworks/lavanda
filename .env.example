# Hostingda Environment Variables sifatida shularni qo‘ying (Render, Railway, Fly, VPS).

PORT=3000

# Admin API kaliti — kuchli tasodifiy qator (masalan: openssl rand -hex 32)
ADMIN_SECRET=

# Ixtiyoriy: loglarda to‘liq URL ko‘rsatish (masalan https://sizning-app.onrender.com)
# Render avtomatik RENDER_EXTERNAL_URL beradi.
# PUBLIC_URL=

# Ixtiyoriy: SQLite faylini doimiy diskga yozish (Render Disk mount yo‘li)
# DATA_DIR=/data
